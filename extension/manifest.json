{
  "manifest_version": 3,
  "name": "Sharely Extension",
  "version": "1.1",
  "description": "One-click access to shared premium services. Powered by Sharely.",
  "action": {
    "default_popup": "./popup.html",
    "default_icon": {
      "16": "./icons/icon-16.png",
      "128": "./icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "./background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "windows": "Alt+Shift+S",
        "mac": "Alt+Shift+S",
        "chromeos": "Alt+Shift+S",
        "linux": "Alt+Shift+S"
      }
    }
  },
  "host_permissions": [
    "*://*/*"
  ],
  "permissions": [
    "cookies",
    "storage",
    "activeTab",
    "contextMenus",
    "tabs"
  ],
  "icons": {
    "16": "./icons/icon-16.png",
    "128": "./icons/icon-128.png"
  }
}
