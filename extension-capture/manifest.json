{
  "manifest_version": 3,
  "name": "Sharely Capture",
  "version": "1.0",
  "description": "One-click session capture companion for Sharely. Reads current site cookies and sends them to your Sharely Admin Dashboard.",
  "action": {
    "default_popup": "./popup.html",
    "default_icon": {
      "16": "./icons/icon-16.png",
      "128": "./icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "./background.js"
  },
  "host_permissions": [
    "*://*/*"
  ],
  "permissions": [
    "cookies",
    "tabs",
    "storage"
  ],
  "icons": {
    "16": "./icons/icon-16.png",
    "128": "./icons/icon-128.png"
  }
}
